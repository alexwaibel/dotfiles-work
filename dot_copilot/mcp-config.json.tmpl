{{- /* GitHub Copilot CLI MCP server config — rendered by chezmoi.
     Schema: https://docs.github.com/en/copilot/how-tos/copilot-cli/customize-copilot/add-mcp-servers
     Loaded by Copilot CLI from ~/.copilot/mcp-config.json (override via COPILOT_HOME). */ -}}
{
  "mcpServers": {
{{- if eq .chezmoi.os "windows" }}
    "azure-devops": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@azure-devops/mcp", "{{ .ado.org }}", "-d", "work", "work-items", "-a", "azcli"],
      "tools": ["*"]
    },
    "azure-kusto": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@azure/mcp@latest", "server", "start", "--namespace", "kusto"],
      "tools": ["*"]
    },
    "ado-wiki": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "{{ .mcpTool.command }}", "mcp", "ado", "--org", "{{ .ado.org }}", "--toolsets", "wiki"],
      "tools": ["*"]
    },
    "icm": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "{{ .mcpTool.command }}", "mcp", "icm"],
      "tools": ["*"]
    },
    "enghub": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "{{ .mcpTool.command }}", "mcp", "enghub"],
      "tools": ["*"]
    },
    "workiq": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "{{ .mcpTool.command }}", "mcp", "workiq"],
      "tools": ["*"]
    },
    "teams-chat": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "{{ .mcpTool.command }}", "mcp", "teams"],
      "tools": ["*"]
    },
    "mail": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "{{ .mcpTool.command }}", "mcp", "mail"],
      "tools": ["*"]
    },
    "playwright": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "--registry", "https://registry.npmjs.org", "@playwright/mcp@latest", "--headless"],
      "tools": ["*"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest", "--browser-url", "http://127.0.0.1:9222"],
      "tools": ["*"]
    }
{{- else }}
    "azure-devops": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "{{ .ado.org }}", "-d", "work", "work-items", "-a", "azcli"],
      "tools": ["*"]
    },
    "azure-kusto": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start", "--namespace", "kusto"],
      "tools": ["*"]
    },
    "ado-wiki": {
      "type": "local",
      "command": "{{ .mcpTool.command }}",
      "args": ["mcp", "ado", "--org", "{{ .ado.org }}", "--toolsets", "wiki"],
      "tools": ["*"]
    },
    "icm": {
      "type": "local",
      "command": "{{ .mcpTool.command }}",
      "args": ["mcp", "icm"],
      "tools": ["*"]
    },
    "enghub": {
      "type": "local",
      "command": "{{ .mcpTool.command }}",
      "args": ["mcp", "enghub"],
      "tools": ["*"]
    },
    "workiq": {
      "type": "local",
      "command": "cmd.exe",
      "args": ["/c", "%APPDATA%\\{{ .mcpTool.command }}\\CurrentVersion\\{{ .mcpTool.command }}.exe mcp workiq"],
      "env": {
        "BROWSER": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe"
      },
      "tools": ["*"]
    },
    "teams-chat": {
      "type": "local",
      "command": "cmd.exe",
      "args": ["/c", "%APPDATA%\\{{ .mcpTool.command }}\\CurrentVersion\\{{ .mcpTool.command }}.exe mcp teams"],
      "env": {
        "BROWSER": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe"
      },
      "tools": ["*"]
    },
    "mail": {
      "type": "local",
      "command": "cmd.exe",
      "args": ["/c", "%APPDATA%\\{{ .mcpTool.command }}\\CurrentVersion\\{{ .mcpTool.command }}.exe mcp mail"],
      "env": {
        "BROWSER": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe"
      },
      "tools": ["*"]
    },
    "playwright": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "--registry", "https://registry.npmjs.org", "@playwright/mcp@latest", "--headless"],
      "tools": ["*"]
    },
    "playwright-mocked": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "--registry", "https://registry.npmjs.org", "@playwright/mcp@latest", "--cdp-endpoint", "http://127.0.0.1:9222"],
      "tools": ["*"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--browser-url", "http://127.0.0.1:9222"],
      "tools": ["*"]
    }
{{- end }}
  }
}
