#!/bin/bash
# Attach a YubiKey to WSL via usbipd (requires prior bind from Windows).
# The bind step is handled by the Windows chezmoi setup script.
# Attach must run each WSL session since it doesn't persist.

set -euo pipefail

if ! command -v usbipd.exe &>/dev/null; then
    echo "ERROR: usbipd.exe not found — install usbipd-win on Windows first."
    exit 1
fi

busid=$(usbipd.exe list 2>/dev/null | grep -i 'yubico\|yubikey' | awk '{print $1}' | head -1)

if [ -z "$busid" ]; then
    echo "ERROR: No YubiKey found. Make sure it's plugged in."
    exit 1
fi

echo "Found YubiKey at bus ID $busid — attaching to WSL ..."
usbipd.exe attach --wsl --busid "$busid"
echo "YubiKey attached. It will detach when unplugged or WSL restarts."
