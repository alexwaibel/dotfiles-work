#!/bin/bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
# Merge mcpServers into existing .claude.json without overwriting runtime state

stdin=$(cat)

if [ -z "$stdin" ] || [ "$(echo "$stdin" | tr -d '[:space:]')" = "" ]; then
    stdin='{}'
fi

{{ if eq .chezmoi.os "windows" -}}
managed_servers='{"azure-devops":{"command":"cmd","args":["/c","npx","-y","@azure-devops/mcp","{{ .ado.org }}","-d","work","work-items","-a","azcli"]}}'
{{ else -}}
managed_servers='{"azure-devops":{"command":"npx","args":["-y","@azure-devops/mcp","{{ .ado.org }}","-d","work","work-items","-a","azcli"]}}'
{{ end -}}

echo "$stdin" | jq --argjson managed "$managed_servers" '
  .mcpServers = ($managed * (.mcpServers // {}))
'
