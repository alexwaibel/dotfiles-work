{{- /* Claude Code settings — rendered by chezmoi, comments stripped in output.
     Key order matches what Claude Code writes when it modifies this file:
     permissions → model → hooks → reasoningEffort. */ -}}
{
  "permissions": {
    "allow": [
{{/* Read-only shell: git and filesystem inspection, no side effects */}}
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
{{/* Read-only shell: chezmoi inspection queries against dotfiles state */}}
      "Bash(chezmoi status:*)",
      "Bash(chezmoi diff:*)",
      "Bash(chezmoi data:*)",
      "Bash(chezmoi managed:*)",
{{/* Git write operations: push is guarded by the PreToolUse hook (guard-git-push.sh) which enforces alwaibel/claude/* branch prefix.
     checkout is needed for worktree agents to create feature branches. */}}
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
{{/* Build tools: yarn install is kept here globally; other yarn commands are in per-repo project settings. */}}
      "Bash(yarn install:*)",
{{/* Azure CLI: Teams channel notifications scoped to our team, and ADO draft PR creation */}}
      "Bash(az rest --method POST --url \"https://graph.microsoft.com/v1.0/teams/{{ .teams.teamId }}:*)",
      "Bash(az repos pr create:*)",
{{/* File tools and cd scoped to project directories (including worktrees created inside repos).
     Background agents cannot prompt for permission so these must be pre-approved.
     Worktree agents inherit the parent session's settings, NOT repo project settings,
     so all needed permissions must be here in user-level settings.
     cd is allowed so agents can set working directory before running git/yarn commands. */}}
{{- $home := .chezmoi.homeDir -}}
{{- range .ado.repos }}
      "Bash(cd {{ $home }}/{{ .name }}:*)",
      "Read(/{{ $home }}/{{ .name }}/**)",
      "Edit(/{{ $home }}/{{ .name }}/**)",
      "Write(/{{ $home }}/{{ .name }}/**)",
      "Grep(/{{ $home }}/{{ .name }}/**)",
      "Glob(/{{ $home }}/{{ .name }}/**)",
{{- end }}
{{/* Chezmoi source directory: dotfiles repo managed by chezmoi. */}}
      "Bash(cd {{ $home }}/.local/share/chezmoi:*)",
      "Read(/{{ $home }}/.local/share/chezmoi/**)",
      "Edit(/{{ $home }}/.local/share/chezmoi/**)",
      "Write(/{{ $home }}/.local/share/chezmoi/**)",
      "Grep(/{{ $home }}/.local/share/chezmoi/**)",
      "Glob(/{{ $home }}/.local/share/chezmoi/**)",
{{/* Logseq notebook: synced via OneDrive. Read/search for daily reviews, edit to mark TODOs done during triage. */}}
      "Read(//mnt/c/Users/alwaibel/OneDrive - Microsoft/Documents/logseq/**)",
      "Grep(//mnt/c/Users/alwaibel/OneDrive - Microsoft/Documents/logseq/**)",
      "Glob(//mnt/c/Users/alwaibel/OneDrive - Microsoft/Documents/logseq/**)",
      "Edit(//mnt/c/Users/alwaibel/OneDrive - Microsoft/Documents/logseq/**)",
{{/* Cockpit state: local markdown files for dashboards, task tracking, and agent status. */}}
      "Read(/{{ $home }}/cockpit/state/**)",
      "Edit(/{{ $home }}/cockpit/state/**)",
      "Write(/{{ $home }}/cockpit/state/**)",
{{/* ADO MCP read-only: sprint/iteration queries, backlog views, work item reads */}}
      "mcp__azure-devops__work_list_team_iterations",
      "mcp__azure-devops__work_list_iterations",
      "mcp__azure-devops__work_get_team_capacity",
      "mcp__azure-devops__work_get_iteration_capacities",
      "mcp__azure-devops__wit_list_backlogs",
      "mcp__azure-devops__wit_list_backlog_work_items",
      "mcp__azure-devops__wit_my_work_items",
      "mcp__azure-devops__wit_get_work_items_batch_by_ids",
      "mcp__azure-devops__wit_get_work_item",
      "mcp__azure-devops__wit_list_work_item_comments",
      "mcp__azure-devops__wit_list_work_item_revisions",
      "mcp__azure-devops__wit_get_work_items_for_iteration",
      "mcp__azure-devops__wit_get_work_item_type",
      "mcp__azure-devops__wit_get_query",
      "mcp__azure-devops__wit_get_query_results_by_id",
{{/* Playwright MCP: read-only browser inspection for visual verification of UI changes.
     Navigate and screenshot are safe — they don't modify state. Snapshot captures accessibility tree. */}}
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_tab_list",
      "mcp__playwright__browser_close",
{{/* Playwright MCP (mocked): connects to mock-browser.ts CDP endpoint for mocked visual verification. Same read-only tools. */}}
      "mcp__playwright-mocked__browser_navigate",
      "mcp__playwright-mocked__browser_take_screenshot",
      "mcp__playwright-mocked__browser_snapshot",
      "mcp__playwright-mocked__browser_tab_list",
      "mcp__playwright-mocked__browser_close",
{{/* Azure Kusto MCP: read-only KQL queries against Azure Data Explorer clusters. All kusto tools are safe (readOnlyHint: true). */}}
      "mcp__azure-kusto__kusto",
{{/* ADO Wiki MCP: read-only wiki browsing and search. Excludes wiki_create_or_update_page (write). */}}
      "mcp__ado-wiki__search_wiki",
      "mcp__ado-wiki__wiki_get_page",
      "mcp__ado-wiki__wiki_get_page_content",
      "mcp__ado-wiki__wiki_list_pages",
      "mcp__ado-wiki__wiki_list_wikis",
      "mcp__ado-wiki__wiki_get_wiki",
      "mcp__ado-wiki__core_list_projects",
      "mcp__ado-wiki__core_list_project_teams",
{{/* ICM MCP: read-only incident queries and metadata. All tools are safe. */}}
      "mcp__icm__get_incident_details_by_id",
      "mcp__icm__search_incidents_by_owning_team_id",
      "mcp__icm__get_teams_by_name",
      "mcp__icm__get_teams_by_public_id",
      "mcp__icm__get_team_by_id",
      "mcp__icm__get_similar_incidents",
      "mcp__icm__get_ai_summary",
      "mcp__icm__get_contact_by_alias",
      "mcp__icm__get_contact_by_id",
      "mcp__icm__get_impacted_ace_customers",
      "mcp__icm__get_impacted_azure_priority0_customers",
      "mcp__icm__get_impacted_s500_customers",
      "mcp__icm__get_impacted_services_regions_clouds",
      "mcp__icm__get_impacted_subscription_count",
      "mcp__icm__get_incident_context",
      "mcp__icm__get_incident_customer_impact",
      "mcp__icm__get_incident_location",
      "mcp__icm__get_mitigation_hints",
      "mcp__icm__get_on_call_schedule_by_team_id",
      "mcp__icm__get_outage_high_priority_events",
      "mcp__icm__get_services_by_names",
      "mcp__icm__get_support_requests_crisit",
      "mcp__icm__is_specific_customer_impacted",
{{/* EngineeringHub MCP: read-only doc search and content retrieval. */}}
      "mcp__enghub__search",
      "mcp__enghub__fetch",
      "mcp__enghub__resolve_service",
      "mcp__enghub__get_node_tree",
      "mcp__enghub__get_service_nodes",
      "mcp__enghub__get_source_link",
{{/* WorkIQ MCP: read-only M365 Copilot queries. */}}
      "mcp__workiq__accept_eula",
      "mcp__workiq__ask_work_iq",
{{/* ADO MCP write: field updates and comments. Safe — ADO tracks full revision history so any change can be viewed and reverted in ADO UI. */}}
      "mcp__azure-devops__wit_update_work_item",
      "mcp__azure-devops__wit_update_work_items_batch",
      "mcp__azure-devops__wit_add_work_item_comment"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/guard-git-push.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-compound-bash.sh"
          }
        ]
      }
    ]
  },
  "reasoningEffort": "medium"
}
